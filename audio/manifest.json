    "text": "The X-ray room is on the second floor.",
    "path": "audio/pb1/pb1_s1_p0.mp3"
  },
  "pb1_s1_p1": {
    "voice": "en-US-JennyNeural",
    "text": "Go straight, then turn left.",
    "path": "audio/pb1/pb1_s1_p1.mp3"
  },
  "pb1_s1_p2": {
    "voice": "en-US-JennyNeural",
    "text": "Follow me, please.",
    "path": "audio/pb1/pb1_s1_p2.mp3"
  },
  "pb1_s1_p3": {
    "voice": "en-US-JennyNeural",
    "text": "I'm not sure — let me find someone to help.",
    "path": "audio/pb1/pb1_s1_p3.mp3"
  },
  "pb1_s1_v0": {
    "voice": "en-US-JennyNeural",
    "text": "elevator",
    "path": "audio/pb1/pb1_s1_v0.mp3"
  },
  "pb1_s1_v1": {
    "voice": "en-US-JennyNeural",
    "text": "corridor",
    "path": "audio/pb1/pb1_s1_v1.mp3"
  },
  "pb1_s1_v2": {
    "voice": "en-US-JennyNeural",
    "text": "waiting room",
    "path": "audio/pb1/pb1_s1_v2.mp3"
  },
  "pb1_s1_v3": {
    "voice": "en-US-JennyNeural",
    "text": "reception",
    "path": "audio/pb1/pb1_s1_v3.mp3"
  },
