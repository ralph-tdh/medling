    "text": "restroom",
    "path": "audio/pb1/pb1_s1_v5.mp3"
  },
  "pb1_s1_v6": {
    "voice": "en-US-JennyNeural",
    "text": "outpatient clinic",
    "path": "audio/pb1/pb1_s1_v6.mp3"
  },
  "pb1_s2_pt": {
    "voice": "en-US-MichelleNeural",
    "text": "How long is the wait?",
    "path": "audio/pb1/pb1_s2_pt.mp3"
  },
  "pb1_s2_p0": {
    "voice": "en-US-MichelleNeural",
    "text": "The wait is approximately 20 minutes.",
    "path": "audio/pb1/pb1_s2_p0.mp3"
  },
  "pb1_s2_p1": {
    "voice": "en-US-MichelleNeural",
    "text": "The doctor is with another patient right now.",
    "path": "audio/pb1/pb1_s2_p1.mp3"
  },
  "pb1_s2_p2": {
    "voice": "en-US-MichelleNeural",
    "text": "We're running a little behind schedule today.",
    "path": "audio/pb1/pb1_s2_p2.mp3"
  },
  "pb1_s2_p3": {
    "voice": "en-US-MichelleNeural",
    "text": "Please have a seat — we'll call your name.",
    "path": "audio/pb1/pb1_s2_p3.mp3"
  },
  "pb1_s2_p4": {
    "voice": "en-US-MichelleNeural",
    "text": "Let me check for you.",
    "path": "audio/pb1/pb1_s2_p4.mp3"
  },
  "pb1_s2_v0": {
    "voice": "en-US-MichelleNeural",
    "text": "appointment",
    "path": "audio/pb1/pb1_s2_v0.mp3"
  },
  "pb1_s2_v1": {
    "voice": "en-US-MichelleNeural",
    "text": "queue",
    "path": "audio/pb1/pb1_s2_v1.mp3"
  },
  "pb1_s2_v2": {
    "voice": "en-US-MichelleNeural",
    "text": "registration desk",
    "path": "audio/pb1/pb1_s2_v2.mp3"
  },
  "pb1_s2_v3": {
    "voice": "en-US-MichelleNeural",
    "text": "consultation room",
    "path": "audio/pb1/pb1_s2_v3.mp3"
  },
  "pb1_s2_v4": {
    "voice": "en-US-MichelleNeural",
    "text": "schedule",
    "path": "audio/pb1/pb1_s2_v4.mp3"
  },
  "pb1_s2_v5": {
    "voice": "en-US-MichelleNeural",
    "text": "check-in",
    "path": "audio/pb1/pb1_s2_v5.mp3"
  },
  "pb1_s3_p0": {
    "voice": "en-US-JennyNeural",
    "text": "Excuse me, can I help you?",
    "path": "audio/pb1/pb1_s3_p0.mp3"
  },
  "pb1_s3_p1": {
    "voice": "en-US-JennyNeural",
    "text": "Are you okay?",
    "path": "audio/pb1/pb1_s3_p1.mp3"
  },
  "pb1_s3_p2": {
    "voice": "en-US-JennyNeural",
    "text": "Are you looking for something?",
    "path": "audio/pb1/pb1_s3_p2.mp3"
  },
  "pb1_s3_p3": {
    "voice": "en-US-JennyNeural",
    "text": "Please come with me — I'll help you.",
    "path": "audio/pb1/pb1_s3_p3.mp3"
  },
  "pb1_s3_p4": {
    "voice": "en-US-JennyNeural",
    "text": "Let me get a nurse for you right away.",
    "path": "audio/pb1/pb1_s3_p4.mp3"
  },
  "pb1_s3_v0": {
    "voice": "en-US-JennyNeural",
    "text": "nurse station",
    "path": "audio/pb1/pb1_s3_v0.mp3"
  },
  "pb1_s3_v1": {
    "voice": "en-US-JennyNeural",
    "text": "wheelchair",
    "path": "audio/pb1/pb1_s3_v1.mp3"
  },
  "pb1_s3_v2": {
    "voice": "en-US-JennyNeural",
    "text": "distressed",
    "path": "audio/pb1/pb1_s3_v2.mp3"
  },
  "pb1_s3_v3": {
    "voice": "en-US-JennyNeural",
    "text": "first aid",
    "path": "audio/pb1/pb1_s3_v3.mp3"
  },
  "pb1_s3_v4": {
    "voice": "en-US-JennyNeural",
    "text": "emergency room",
    "path": "audio/pb1/pb1_s3_v4.mp3"
  },
  "pb1_s3_v5": {
    "voice": "en-US-JennyNeural",
    "text": "escort",
    "path": "audio/pb1/pb1_s3_v5.mp3"
  },
  "pb1_s4_pt": {
    "voice": "en-US-GuyNeural",
    "text": "What is this medication for?",
    "path": "audio/pb1/pb1_s4_pt.mp3"
  },
  "pb1_s4_p0": {
    "voice": "en-US-GuyNeural",
    "text": "Let me find the pharmacist for you.",
    "path": "audio/pb1/pb1_s4_p0.mp3"
  },
  "pb1_s4_p1": {
    "voice": "en-US-GuyNeural",
    "text": "I'd suggest asking the doctor directly.",
    "path": "audio/pb1/pb1_s4_p1.mp3"
  },
  "pb1_s4_p2": {
    "voice": "en-US-GuyNeural",
    "text": "Let me check your records.",
    "path": "audio/pb1/pb1_s4_p2.mp3"
  },
  "pb1_s4_p3": {
    "voice": "en-US-GuyNeural",
    "text": "Your appointment is on Monday — let me confirm.",
    "path": "audio/pb1/pb1_s4_p3.mp3"
  },
  "pb1_s4_v0": {
    "voice": "en-US-GuyNeural",
    "text": "prescription",
    "path": "audio/pb1/pb1_s4_v0.mp3"
  },
  "pb1_s4_v1": {
    "voice": "en-US-GuyNeural",
    "text": "dosage",
    "path": "audio/pb1/pb1_s4_v1.mp3"
  },
  "pb1_s4_v2": {
    "voice": "en-US-GuyNeural",
    "text": "pharmacist",
    "path": "audio/pb1/pb1_s4_v2.mp3"
  },
  "pb1_s4_v3": {
    "voice": "en-US-GuyNeural",
    "text": "refill",
    "path": "audio/pb1/pb1_s4_v3.mp3"
  },
  "pb1_s4_v4": {
    "voice": "en-US-GuyNeural",
    "text": "follow-up",
    "path": "audio/pb1/pb1_s4_v4.mp3"
  },
  "pb1_s4_v5": {
    "voice": "en-US-GuyNeural",
    "text": "discharge",
    "path": "audio/pb1/pb1_s4_v5.mp3"
  },
  "pb1_q0": {
    "voice": "en-CA-LiamNeural",
    "text": "Patient: \"Where is the elevator?\" — Best response:",
    "path": "audio/pb1/pb1_q0.mp3"
  },
  "pb1_q1": {
    "voice": "en-CA-LiamNeural",
    "text": "\"We're running a little behind schedule today\" means:",
    "path": "audio/pb1/pb1_q1.mp3"
  },
  "pb1_q2": {
    "voice": "en-CA-LiamNeural",
    "text": "You see a patient in the hallway, looking worried. What should you say first?",
    "path": "audio/pb1/pb1_q2.mp3"
  },
  "pb1_q3": {
    "voice": "en-CA-LiamNeural",
    "text": "Patient asks about their appointment but you're not managing their case. What do you say?",
    "path": "audio/pb1/pb1_q3.mp3"
  },
  "pb1_q4": {
    "voice": "en-CA-LiamNeural",
    "text": "Which phrase do you use when you physically walk WITH the patient to show them the way?",
    "path": "audio/pb1/pb1_q4.mp3"
  },
  "pb2_s1_pt": {
    "voice": "en-US-JennyNeural",
    "text": "\"Gastritis\" — what does this actually mean?",
    "path": "audio/pb2/pb2_s1_pt.mp3"
  },
  "pb2_s1_p0": {
    "voice": "en-US-JennyNeural",
    "text": "The suffix \"-itis\" means inflammation.",
    "path": "audio/pb2/pb2_s1_p0.mp3"
  },
  "pb2_s1_p1": {
    "voice": "en-US-JennyNeural",
    "text": "Gastritis means inflammation of the stomach.",
    "path": "audio/pb2/pb2_s1_p1.mp3"
  },
  "pb2_s1_p2": {
    "voice": "en-US-JennyNeural",
    "text": "You may have heard of hepatitis — that's inflammation of the liver.",
    "path": "audio/pb2/pb2_s1_p2.mp3"
  },
  "pb2_s1_p3": {
    "voice": "en-US-JennyNeural",
    "text": "Any word ending in \"-itis\" describes a type of inflammation.",
    "path": "audio/pb2/pb2_s1_p3.mp3"
  },
  "pb2_s1_v0": {
    "voice": "en-US-JennyNeural",
    "text": "gastritis",
    "path": "audio/pb2/pb2_s1_v0.mp3"
  },
  "pb2_s1_v1": {
    "voice": "en-US-JennyNeural",
    "text": "appendicitis",
    "path": "audio/pb2/pb2_s1_v1.mp3"
  },
  "pb2_s1_v2": {
    "voice": "en-US-JennyNeural",
    "text": "hepatitis",
    "path": "audio/pb2/pb2_s1_v2.mp3"
  },
  "pb2_s1_v3": {
    "voice": "en-US-JennyNeural",
    "text": "bronchitis",
    "path": "audio/pb2/pb2_s1_v3.mp3"
  },
  "pb2_s1_v4": {
    "voice": "en-US-JennyNeural",
    "text": "arthritis",
    "path": "audio/pb2/pb2_s1_v4.mp3"
  },
  "pb2_s1_v5": {
    "voice": "en-US-JennyNeural",
    "text": "dermatitis",
    "path": "audio/pb2/pb2_s1_v5.mp3"
  },
  "pb2_s1_v6": {
    "voice": "en-US-JennyNeural",
    "text": "tonsillitis",
    "path": "audio/pb2/pb2_s1_v6.mp3"
  },
  "pb2_s2_pt": {
    "voice": "en-US-JennyNeural",
    "text": "\"Tachycardia\" — what does that actually mean?",
    "path": "audio/pb2/pb2_s2_pt.mp3"
  },
  "pb2_s2_p0": {
    "voice": "en-US-JennyNeural",
    "text": "The root \"cardio-\" or \"-cardia\" refers to the heart.",
    "path": "audio/pb2/pb2_s2_p0.mp3"
  },
  "pb2_s2_p1": {
    "voice": "en-US-JennyNeural",
    "text": "Tachycardia means a fast heart rate — \"tachy-\" means fast.",
    "path": "audio/pb2/pb2_s2_p1.mp3"
  },
  "pb2_s2_p2": {
    "voice": "en-US-JennyNeural",
    "text": "Bradycardia is the opposite — a slow heart rate.",
    "path": "audio/pb2/pb2_s2_p2.mp3"
  },
  "pb2_s2_p3": {
    "voice": "en-US-JennyNeural",
    "text": "Cardiac arrest means the heart has stopped completely.",
    "path": "audio/pb2/pb2_s2_p3.mp3"
  },
  "pb2_s2_v0": {
    "voice": "en-US-JennyNeural",
    "text": "cardiac",
    "path": "audio/pb2/pb2_s2_v0.mp3"
  },
  "pb2_s2_v1": {
    "voice": "en-US-JennyNeural",
    "text": "tachycardia",
    "path": "audio/pb2/pb2_s2_v1.mp3"
  },
  "pb2_s2_v2": {
    "voice": "en-US-JennyNeural",
    "text": "bradycardia",
    "path": "audio/pb2/pb2_s2_v2.mp3"
  },
  "pb2_s2_v3": {
    "voice": "en-US-JennyNeural",
    "text": "cardiomegaly",
    "path": "audio/pb2/pb2_s2_v3.mp3"
  },
  "pb2_s2_v4": {
    "voice": "en-US-JennyNeural",
    "text": "cardiologist",
    "path": "audio/pb2/pb2_s2_v4.mp3"
  },
  "pb2_s2_v5": {
    "voice": "en-US-JennyNeural",
    "text": "myocardial",
    "path": "audio/pb2/pb2_s2_v5.mp3"
  },
  "pb2_s2_v6": {
    "voice": "en-US-JennyNeural",
    "text": "palpitation",
    "path": "audio/pb2/pb2_s2_v6.mp3"
  },
  "pb2_s3_pt": {
    "voice": "en-US-GuyNeural",
    "text": "\"Appendectomy\" — can you tell what will happen just from the name?",
    "path": "audio/pb2/pb2_s3_pt.mp3"
  },
  "pb2_s3_p0": {
    "voice": "en-US-GuyNeural",
    "text": "The suffix \"-ectomy\" means surgical removal.",
    "path": "audio/pb2/pb2_s3_p0.mp3"
  },
  "pb2_s3_p1": {
    "voice": "en-US-GuyNeural",
    "text": "An appendectomy is the removal of the appendix.",
    "path": "audio/pb2/pb2_s3_p1.mp3"
  },
  "pb2_s3_p2": {
    "voice": "en-US-GuyNeural",
    "text": "A cholecystectomy removes the gallbladder — \"chole\" = bile, \"cyst\" = sac.",
    "path": "audio/pb2/pb2_s3_p2.mp3"
  },
  "pb2_s3_p3": {
    "voice": "en-US-GuyNeural",
    "text": "Know the root, and you know exactly what is being removed.",
    "path": "audio/pb2/pb2_s3_p3.mp3"
  },
  "pb2_s3_v0": {
    "voice": "en-US-GuyNeural",
    "text": "appendectomy",
    "path": "audio/pb2/pb2_s3_v0.mp3"
  },
  "pb2_s3_v1": {
    "voice": "en-US-GuyNeural",
    "text": "cholecystectomy",
    "path": "audio/pb2/pb2_s3_v1.mp3"
  },
  "pb2_s3_v2": {
    "voice": "en-US-GuyNeural",
    "text": "mastectomy",
    "path": "audio/pb2/pb2_s3_v2.mp3"
  },
  "pb2_s3_v3": {
    "voice": "en-US-GuyNeural",
    "text": "tonsillectomy",
    "path": "audio/pb2/pb2_s3_v3.mp3"
  },
  "pb2_s3_v4": {
    "voice": "en-US-GuyNeural",
    "text": "hysterectomy",
    "path": "audio/pb2/pb2_s3_v4.mp3"
  },
  "pb2_s3_v5": {
    "voice": "en-US-GuyNeural",
    "text": "nephrectomy",
    "path": "audio/pb2/pb2_s3_v5.mp3"
  },
  "pb2_s3_v6": {
    "voice": "en-US-GuyNeural",
    "text": "gastrectomy",
    "path": "audio/pb2/pb2_s3_v6.mp3"
  },
  "pb2_s4_pt": {
    "voice": "en-US-GuyNeural",
    "text": "\"Referred to a gastroenterologist\" — who exactly is that?",
    "path": "audio/pb2/pb2_s4_pt.mp3"
  },
  "pb2_s4_p0": {
    "voice": "en-US-GuyNeural",
    "text": "\"-ology\" means the study of — and \"-ologist\" is the specialist.",
    "path": "audio/pb2/pb2_s4_p0.mp3"
  },
  "pb2_s4_p1": {
    "voice": "en-US-GuyNeural",
    "text": "A gastroenterologist specializes in the digestive system.",
    "path": "audio/pb2/pb2_s4_p1.mp3"
  },
  "pb2_s4_p2": {
    "voice": "en-US-GuyNeural",
    "text": "\"Gastro-\" means stomach, and \"entero-\" means intestine.",
    "path": "audio/pb2/pb2_s4_p2.mp3"
  },
  "pb2_s4_p3": {
    "voice": "en-US-GuyNeural",
    "text": "Know the root, and you know exactly which organ that specialist treats.",
    "path": "audio/pb2/pb2_s4_p3.mp3"
  },
  "pb2_s4_v0": {
    "voice": "en-US-GuyNeural",
    "text": "cardiologist",
    "path": "audio/pb2/pb2_s4_v0.mp3"
  },
  "pb2_s4_v1": {
    "voice": "en-US-GuyNeural",
    "text": "neurologist",
    "path": "audio/pb2/pb2_s4_v1.mp3"
  },
  "pb2_s4_v2": {
    "voice": "en-US-GuyNeural",
    "text": "gastroenterologist",
    "path": "audio/pb2/pb2_s4_v2.mp3"
  },
  "pb2_s4_v3": {
    "voice": "en-US-GuyNeural",
    "text": "hepatologist",
    "path": "audio/pb2/pb2_s4_v3.mp3"
  },
  "pb2_s4_v4": {
    "voice": "en-US-GuyNeural",
    "text": "pulmonologist",
    "path": "audio/pb2/pb2_s4_v4.mp3"
  },
  "pb2_s4_v5": {
    "voice": "en-US-GuyNeural",
    "text": "dermatologist",
    "path": "audio/pb2/pb2_s4_v5.mp3"
  },
  "pb2_s4_v6": {
    "voice": "en-US-GuyNeural",
    "text": "oncologist",
    "path": "audio/pb2/pb2_s4_v6.mp3"
  },
  "pb2_q0": {
    "voice": "en-US-MichelleNeural",
    "text": "What does the suffix \"-itis\" mean in medical English?",
    "path": "audio/pb2/pb2_q0.mp3"
  },
  "pb2_q1": {
    "voice": "en-US-MichelleNeural",
    "text": "\"Tachy-\" as in \"tachycardia\" means:",
    "path": "audio/pb2/pb2_q1.mp3"
  },
  "pb2_q2": {
    "voice": "en-US-MichelleNeural",
    "text": "A patient is scheduled for a \"nephrectomy.\" Which organ is involved?",
    "path": "audio/pb2/pb2_q2.mp3"
  },
  "pb2_q3": {
    "voice": "en-US-MichelleNeural",
    "text": "Which of these words means \"inflammation of the liver\"?",
    "path": "audio/pb2/pb2_q3.mp3"
  },
  "pb2_q4": {
    "voice": "en-US-MichelleNeural",
    "text": "A referral says \"see a pulmonologist.\" This doctor specializes in:",
    "path": "audio/pb2/pb2_q4.mp3"
  },
  "pb3_s1_p0": {
    "voice": "en-CA-LiamNeural",
    "text": "Hello, I'm Dr. Minh. I'll be taking care of you today.",
    "path": "audio/pb3/pb3_s1_p0.mp3"
  },
  "pb3_s1_p1": {
    "voice": "en-CA-LiamNeural",
    "text": "Good morning — my name is Dr. Lan from the internal medicine department.",
    "path": "audio/pb3/pb3_s1_p1.mp3"
  },
  "pb3_s1_p2": {
    "voice": "en-CA-LiamNeural",
    "text": "Hi, I'm Dr. Nam, the resident on duty this morning. Nice to meet you.",
    "path": "audio/pb3/pb3_s1_p2.mp3"
  },
  "pb3_s1_p3": {
    "voice": "en-CA-LiamNeural",
    "text": "Please don't worry — I'm Dr. Pham, and I'm here to help.",
    "path": "audio/pb3/pb3_s1_p3.mp3"
  },
  "pb3_s1_v0": {
    "voice": "en-CA-LiamNeural",
    "text": "introduction",
    "path": "audio/pb3/pb3_s1_v0.mp3"
  },
  "pb3_s1_v1": {
    "voice": "en-CA-LiamNeural",
    "text": "encounter",
    "path": "audio/pb3/pb3_s1_v1.mp3"
  },
  "pb3_s1_v2": {
    "voice": "en-CA-LiamNeural",
    "text": "department",
    "path": "audio/pb3/pb3_s1_v2.mp3"
  },
  "pb3_s1_v3": {
    "voice": "en-CA-LiamNeural",
    "text": "internal medicine",
    "path": "audio/pb3/pb3_s1_v3.mp3"
  },
  "pb3_s1_v4": {
    "voice": "en-CA-LiamNeural",
    "text": "resident",
    "path": "audio/pb3/pb3_s1_v4.mp3"
  },
  "pb3_s1_v5": {
    "voice": "en-CA-LiamNeural",
    "text": "on duty",
    "path": "audio/pb3/pb3_s1_v5.mp3"
  },
  "pb3_s2_pt": {
    "voice": "en-US-GuyNeural",
    "text": "Well... I've been having some problems. I'm not really sure where to start.",
