  "pb3_s2_v4": {
    "voice": "en-US-GuyNeural",
    "text": "consult",
    "path": "audio/pb3/pb3_s2_v4.mp3"
  },
  "pb3_s3_pt": {
    "voice": "en-CA-LiamNeural",
    "text": "The pain started about three days ago. It sort of comes and goes... it's hard to describe, really.",
